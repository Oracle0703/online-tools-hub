---
import { recentReleases, type ReleaseEntry } from "../lib/experience-content";
import { pathFor } from "../lib/tool-registry";

export type Props = {
  releases?: readonly ReleaseEntry[];
  eyebrow?: string;
  title?: string;
  description?: string;
  headingId?: string;
  limit?: number;
  highlightsPerRelease?: number;
  showArchiveLink?: boolean;
};

const {
  releases = recentReleases,
  eyebrow = "持续改进",
  title = "最近更新",
  description = "新能力、体验调整和隐私相关变化，都保留清楚的版本记录。",
  headingId = "recent-updates-title",
  limit = 3,
  highlightsPerRelease = 2,
  showArchiveLink = true,
} = Astro.props;

const visibleReleases = releases.slice(0, Math.max(0, limit));
const visibleHighlightCount = Math.max(0, highlightsPerRelease);
const dateFormatter = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
});

const formatDate = (date: ReleaseEntry["date"]) =>
  dateFormatter.format(new Date(`${date}T00:00:00Z`));
---

<section class="recent-updates" aria-labelledby={headingId}>
  <header class="recent-updates__heading">
    <div>
      <p class="eyebrow">{eyebrow}</p>
      <h2 id={headingId}>{title}</h2>
      {description && <p>{description}</p>}
    </div>
    {
      showArchiveLink && (
        <a class="recent-updates__archive" href={pathFor("/changelog/")}>
          完整更新日志 <span aria-hidden="true">→</span>
        </a>
      )
    }
  </header>

  <ol class="recent-updates__list">
    {
      visibleReleases.map((release) => (
        <li>
          <article class="release-card">
            <div class="release-card__meta">
              <span>v{release.version}</span>
              <time datetime={release.date}>{formatDate(release.date)}</time>
            </div>
            <p class="release-card__theme">{release.theme}</p>
            <h3>{release.title}</h3>
            <p class="release-card__summary">{release.summary}</p>
            {visibleHighlightCount > 0 && (
              <ul>
                {release.changes
                  .slice(0, visibleHighlightCount)
                  .map((change) => (
                    <li>{change.replace(/；$/, "")}</li>
                  ))}
              </ul>
            )}
          </article>
        </li>
      ))
    }
  </ol>
</section>

<style>
  .recent-updates {
    display: grid;
    gap: clamp(var(--space-5), 4vw, var(--space-7));
  }

  .recent-updates__heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: var(--space-5);
  }

  .recent-updates__heading > div {
    max-width: 45rem;
  }

  .recent-updates__heading .eyebrow {
    margin-bottom: var(--space-2);
  }

  .recent-updates__heading h2 {
    margin-bottom: var(--space-3);
  }

  .recent-updates__archive {
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
    min-height: 2.75rem;
    gap: var(--space-2);
    color: var(--brand-ink);
    font-size: 0.84rem;
    font-weight: 800;
  }

  .recent-updates__archive:hover {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .recent-updates__list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-4);
    padding: 0;
    counter-reset: release;
    list-style: none;
  }

  .recent-updates__list > li,
  .release-card {
    min-width: 0;
    height: 100%;
  }

  .release-card {
    display: flex;
    flex-direction: column;
    padding: clamp(var(--space-4), 2.5vw, var(--space-5));
    border: 1px solid var(--line);
    border-top: 3px solid var(--brand);
    border-radius: var(--radius-md);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
  }

  .release-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
    color: var(--muted);
    font-size: 0.72rem;
  }

  .release-card__meta span {
    padding: 0.3rem 0.48rem;
    border-radius: 999px;
    background: var(--brand-soft);
    color: var(--brand-ink);
    font-weight: 850;
    letter-spacing: 0.02em;
  }

  .release-card__theme {
    margin-bottom: var(--space-2);
    color: var(--teal);
    font-size: 0.7rem;
    font-weight: 850;
    letter-spacing: 0.06em;
  }

  .release-card h3 {
    margin-bottom: var(--space-3);
    font-size: 1.12rem;
  }

  .release-card__summary {
    font-size: 0.84rem;
    line-height: 1.65;
  }

  .release-card ul {
    display: grid;
    gap: var(--space-2);
    margin-top: var(--space-4);
    padding: var(--space-4) 0 0 1.05rem;
    border-top: 1px solid var(--line);
    color: var(--ink-soft);
    font-size: 0.77rem;
    line-height: 1.55;
  }

  .release-card li::marker {
    color: var(--brand);
  }

  @media (max-width: 58rem) {
    .recent-updates__list {
      grid-template-columns: minmax(0, 1fr);
    }

    .release-card {
      display: grid;
      grid-template-columns: minmax(9rem, 0.7fr) minmax(0, 1.3fr);
      column-gap: var(--space-5);
    }

    .release-card__meta,
    .release-card__theme {
      grid-column: 1;
    }

    .release-card h3,
    .release-card__summary,
    .release-card ul {
      grid-column: 2;
    }

    .release-card h3 {
      grid-row: 1;
      align-self: center;
      margin-bottom: var(--space-3);
    }

    .release-card__summary {
      grid-row: 2 / span 2;
    }
  }

  @media (max-width: 42rem) {
    .recent-updates__heading {
      align-items: start;
      flex-direction: column;
    }

    .release-card {
      display: flex;
    }

    .release-card__meta {
      align-items: start;
      flex-direction: column;
      gap: var(--space-2);
    }
  }
</style>
