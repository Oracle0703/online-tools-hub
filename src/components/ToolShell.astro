---
import ComingSoonTool from "./ComingSoonTool";
import LocalBadge from "./LocalBadge.astro";
import ToolCard from "./ToolCard.astro";
import {
  bytesToDisplay,
  enabledTools,
  getCategoryBySlug,
  pathFor,
  type ToolDefinition,
} from "../lib/tool-registry";

type Props = {
  tool: ToolDefinition;
};

const { tool } = Astro.props;
const category = getCategoryBySlug(tool.category);
const sameCategory = enabledTools.filter(
  (candidate) =>
    candidate.id !== tool.id && candidate.category === tool.category,
);
const fallback = enabledTools.filter(
  (candidate) =>
    candidate.id !== tool.id && candidate.category !== tool.category,
);
const relatedTools = [...sameCategory, ...fallback].slice(0, 2);
const maxTextSize = bytesToDisplay(tool.limits.maxTextBytes);

const specialNotes: Record<string, string> = {
  "json-formatter":
    "超出 JavaScript 安全整数范围的数字必须谨慎处理；正式版本不会静默改写原始值。",
  "base64-codec":
    "Base64 是编码，不是加密。请勿用它保护密码、令牌或其他机密信息。",
  "url-codec": "本工具只转换文本，不会访问、预览或验证你输入的网址。",
  "unix-timestamp": "转换结果会同时标明本地时区和 UTC，避免时区含义不清。",
  "uuid-generator":
    "正式版本将使用 crypto.randomUUID() 或等价的密码学安全随机源。",
};
---

<div class="container page-shell tool-page">
  <nav class="breadcrumbs" aria-label="面包屑">
    <a href={pathFor("/")}>首页</a>
    <span aria-hidden="true">/</span>
    <a href={pathFor("/tools/")}>工具</a>
    <span aria-hidden="true">/</span>
    {
      category && (
        <a href={pathFor(`/categories/${category.slug}/`)}>{category.title}</a>
      )
    }
  </nav>

  <header class="tool-hero">
    <div class="tool-mark tool-mark--large" aria-hidden="true">{tool.mark}</div>
    <div class="tool-hero__copy">
      <p class="eyebrow">{category?.title}</p>
      <h1>{tool.title}</h1>
      <p>{tool.description}</p>
      <div class="tool-hero__meta">
        <LocalBadge />
        {maxTextSize && <span class="soft-pill">文本上限 {maxTextSize}</span>}
        <span class="soft-pill">无需登录</span>
      </div>
    </div>
  </header>

  <div class="tool-layout">
    <section aria-label={`${tool.title}交互区`}>
      <slot name="workspace">
        <ComingSoonTool
          client:visible
          title={tool.title}
          maxTextSize={maxTextSize}
        />
      </slot>
    </section>

    <aside class="privacy-panel" aria-labelledby="privacy-panel-title">
      <span class="privacy-panel__icon" aria-hidden="true">✓</span>
      <div>
        <p class="eyebrow">隐私状态</p>
        <h2 id="privacy-panel-title">内容留在此设备</h2>
        <p>
          工具转换在浏览器内完成。输入不会写入网址、浏览器存储或应用服务器。
        </p>
        <a class="text-link" href={pathFor("/privacy/")}
          >了解数据处理原则 <span aria-hidden="true">→</span></a
        >
      </div>
    </aside>
  </div>

  <section class="content-section content-grid" aria-labelledby="guide-title">
    <div>
      <p class="eyebrow">使用指南</p>
      <h2 id="guide-title">三步完成处理</h2>
    </div>
    <ol class="step-list">
      <li>
        <span>01</span><div>
          <strong>输入内容</strong><p>粘贴文本或填写需要转换的值。</p>
        </div>
      </li>
      <li>
        <span>02</span><div>
          <strong>确认选项</strong><p>选择格式或模式，然后执行处理。</p>
        </div>
      </li>
      <li>
        <span>03</span><div>
          <strong>取回结果</strong><p>检查结果后主动复制或下载。</p>
        </div>
      </li>
    </ol>
  </section>

  <section class="notice-card" aria-labelledby="safety-note-title">
    <span aria-hidden="true">!</span>
    <div>
      <h2 id="safety-note-title">使用前请注意</h2>
      <p>{specialNotes[tool.slug]}</p>
    </div>
  </section>

  <section class="content-section faq-section" aria-labelledby="faq-title">
    <div>
      <p class="eyebrow">常见问题</p>
      <h2 id="faq-title">你可能想知道</h2>
    </div>
    <div class="faq-list">
      <details>
        <summary>我的输入会上传到服务器吗？</summary>
        <p>
          不会。这个工具被设计为纯浏览器本地处理，页面也不会把输入写入 URL
          或持久化存储。
        </p>
      </details>
      <details>
        <summary>刷新页面后还能恢复刚才的内容吗？</summary>
        <p>
          不能。为减少敏感内容残留，输入默认只存在于当前页面内存，刷新或关闭页面后不会恢复。
        </p>
      </details>
      <details>
        <summary>移动设备上可以使用吗？</summary>
        <p>
          可以。工具页采用响应式布局，并保留键盘焦点和屏幕阅读器所需的标签。
        </p>
      </details>
    </div>
  </section>

  <section class="content-section" aria-labelledby="related-title">
    <div class="section-heading section-heading--row">
      <div>
        <p class="eyebrow">继续探索</p><h2 id="related-title">相关工具</h2>
      </div>
      <a class="text-link" href={pathFor("/tools/")}
        >查看全部 <span aria-hidden="true">→</span></a
      >
    </div>
    <div class="tool-grid tool-grid--two">
      {relatedTools.map((related) => <ToolCard tool={related} />)}
    </div>
  </section>
</div>
