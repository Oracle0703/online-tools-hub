---
import ComingSoonTool from "./ComingSoonTool";
import TaskRecipes from "./TaskRecipes.astro";
import ToolCard from "./ToolCard.astro";
import ToolFavoriteButton from "./ToolFavoriteButton";
import ToolVisitTracker from "./ToolVisitTracker";
import { getToolPageContent } from "../lib/tool-content";
import { getToolUseCases } from "../lib/experience-content";
import {
  bytesToDisplay,
  enabledTools,
  getCategoryBySlug,
  pathFor,
  type ToolDefinition,
} from "../lib/tool-registry";

type Props = {
  tool: ToolDefinition;
};

const { tool } = Astro.props;
const category = getCategoryBySlug(tool.category);
const sameCategory = enabledTools.filter(
  (candidate) =>
    candidate.id !== tool.id && candidate.category === tool.category,
);
const fallback = enabledTools.filter(
  (candidate) =>
    candidate.id !== tool.id && candidate.category !== tool.category,
);
const relatedTools = [...sameCategory, ...fallback].slice(0, 2);
const maxTextSize = bytesToDisplay(tool.limits.maxTextBytes);
const maxFileSize = bytesToDisplay(tool.limits.maxFileBytes);
const pageContent = getToolPageContent(tool.slug);
const useCases = getToolUseCases(tool.slug);
const isImageCompressor = tool.slug === "image-compressor";
const isLocalTool = tool.privacyMode === "local";
---

<div
  class:list={[
    "container page-shell tool-page",
    { "tool-page--image": isImageCompressor },
  ]}
>
  <ToolVisitTracker client:load slug={tool.slug} />

  <nav class="breadcrumbs" aria-label="面包屑">
    <a href={pathFor("/")}>首页</a>
    <span aria-hidden="true">/</span>
    <a href={pathFor("/tools/")}>工具</a>
    <span aria-hidden="true">/</span>
    {
      category && (
        <a href={pathFor(`/categories/${category.slug}/`)}>{category.title}</a>
      )
    }
    <span aria-hidden="true">/</span>
    <span aria-current="page">{tool.shortTitle}</span>
  </nav>

  <header class="tool-hero">
    <div class="tool-mark tool-mark--large" aria-hidden="true">{tool.mark}</div>
    <div class="tool-hero__copy">
      <p class="eyebrow">{category?.title}</p>
      <h1>{tool.title}</h1>
      <p>{tool.description}</p>
      <div class="tool-hero__meta">
        {maxTextSize && <span class="soft-pill">文本上限 {maxTextSize}</span>}
        {maxFileSize && <span class="soft-pill">单文件上限 {maxFileSize}</span>}
        <ToolFavoriteButton
          client:load
          slug={tool.slug}
          toolName={tool.shortTitle}
        />
      </div>
    </div>
  </header>

  <div
    class:list={[
      "tool-layout",
      { "tool-layout--immersive": isImageCompressor },
    ]}
    data-tool-capabilities={tool.capabilities.join(" ")}
    data-tool-slug={tool.slug}
  >
    <aside
      class:list={["privacy-panel", { "privacy-panel--network": !isLocalTool }]}
      aria-labelledby="privacy-panel-title"
    >
      <span class="privacy-panel__icon" aria-hidden="true">
        {isLocalTool ? "✓" : "↗"}
      </span>
      <div class="privacy-panel__copy">
        <div>
          <p class="eyebrow">处理状态</p>
          <h2 id="privacy-panel-title">
            {isLocalTool ? "本地处理 · 0 B 上传" : "此工具需要联网"}
          </h2>
        </div>
        {
          isLocalTool ? (
            <p>
              输入只存在于当前标签页内存，关闭或刷新后清除，不写入网址、浏览器存储或应用服务器。
            </p>
          ) : (
            <div class="privacy-panel__network-details">
              <p>
                请求接收方：
                <a href={tool.network?.providerUrl} rel="noreferrer">
                  {tool.network?.providerName ?? "待配置的第三方服务"}
                </a>
              </p>
              <p>
                发送字段：
                {tool.network?.sentFields.join("、") ??
                  "尚未配置，工具不可发布"}
              </p>
              <p>用途：{tool.network?.purpose ?? "尚未配置，工具不可发布"}</p>
              <p>
                触发方式：{tool.network?.trigger ?? "尚未配置，工具不可发布"}
              </p>
            </div>
          )
        }
        <a class="text-link" href={pathFor("/privacy/")}>
          隐私详情 <span aria-hidden="true">→</span>
        </a>
      </div>
    </aside>

    <section aria-label={`${tool.title}交互区`} data-tool-region="workspace">
      <slot name="workspace">
        <ComingSoonTool
          client:visible
          title={tool.title}
          maxTextSize={maxTextSize}
        />
      </slot>
    </section>
  </div>

  {
    useCases.length > 0 && (
      <div class="content-section">
        <TaskRecipes
          recipes={useCases}
          eyebrow="实际场景"
          title={`什么时候使用${tool.shortTitle}`}
          description="这些场景说明工具适合解决的问题、完成后的判断标准，以及容易忽略的边界。"
          headingId="tool-use-cases-title"
          density="compact"
        />
      </div>
    )
  }

  <section class="content-section content-grid" aria-labelledby="guide-title">
    <div>
      <p class="eyebrow">使用指南</p>
      <h2 id="guide-title">{pageContent.guideTitle}</h2>
    </div>
    <ol class="step-list">
      {
        pageContent.steps.map((step, index) => (
          <li>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <div>
              <strong>{step.title}</strong>
              <p>{step.description}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="notice-card" aria-labelledby="safety-note-title">
    <span aria-hidden="true">!</span>
    <div>
      <h2 id="safety-note-title">使用前请注意</h2>
      <p>{pageContent.notice}</p>
    </div>
  </section>

  <section class="content-section faq-section" aria-labelledby="faq-title">
    <div>
      <p class="eyebrow">常见问题</p>
      <h2 id="faq-title">你可能想知道</h2>
    </div>
    <div class="faq-list">
      {
        pageContent.faqs.map((faq) => (
          <details>
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))
      }
    </div>
  </section>

  <section class="content-section" aria-labelledby="related-title">
    <div class="section-heading section-heading--row">
      <div>
        <p class="eyebrow">继续探索</p><h2 id="related-title">相关工具</h2>
      </div>
      <a class="text-link" href={pathFor("/tools/")}
        >查看全部 <span aria-hidden="true">→</span></a
      >
    </div>
    <div class="tool-grid tool-grid--two">
      {relatedTools.map((related) => <ToolCard tool={related} />)}
    </div>
  </section>
</div>
