---
import LocalBadge from "./LocalBadge.astro";
import {
  getCategoryBySlug,
  pathFor,
  type ToolDefinition,
} from "../lib/tool-registry";

type Props = {
  tool: ToolDefinition;
};

const { tool } = Astro.props;
const category = getCategoryBySlug(tool.category);
---

<article class="tool-card">
  <a
    class="tool-card__link"
    href={pathFor(`/tools/${tool.slug}/`)}
    aria-label={`打开${tool.title}`}
  >
    <div class="tool-card__topline">
      <span class="tool-mark" aria-hidden="true">{tool.mark}</span>
      <LocalBadge compact mode={tool.privacyMode} />
    </div>
    <div>
      <p class="eyebrow">{category?.title}</p>
      <h3>{tool.shortTitle}</h3>
      <p>{tool.description}</p>
    </div>
  </a>
</article>
