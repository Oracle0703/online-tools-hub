---
import { pathFor } from "../lib/tool-registry";
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <a class="brand brand--footer" href={pathFor("/")}>
        <span class="brand__mark" aria-hidden="true"
          ><span>{`{`}</span><span>{`}`}</span></span
        >
        <span class="brand__copy"><strong>Online Tools Hub</strong></span>
      </a>
      <p>在浏览器里处理数据，内容不离开你的设备。</p>
    </div>

    <nav class="site-footer__links" aria-label="页脚导航">
      <a href={pathFor("/tools/")}>工具</a>
      <a href={pathFor("/workflows/")}>本地工作流</a>
      <a href={pathFor("/categories/")}>分类</a>
      <a href={pathFor("/guides/")}>知识中心</a>
      <a href={pathFor("/privacy/")}>隐私</a>
      <a href={pathFor("/about/")}>关于</a>
      <a href={pathFor("/changelog/")}>更新日志</a>
      <a href={pathFor("/THIRD_PARTY_NOTICES.txt")}>第三方许可</a>
      <a
        href="https://github.com/Oracle0703/online-tools-hub"
        target="_blank"
        rel="noreferrer">GitHub ↗</a
      >
    </nav>
  </div>
  <div class="container site-footer__bottom">
    <span>© 2026 Online Tools Hub</span>
    <span>无需登录 · 本地处理 · 开源透明</span>
  </div>
</footer>
