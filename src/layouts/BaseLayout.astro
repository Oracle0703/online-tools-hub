---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import PwaManager from "../components/PwaManager";
import { pathFor } from "../lib/tool-registry";
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
  noindex?: boolean;
  pageClass?: string;
  canonical?: string | URL | false;
  keywords?: string[];
  imageAlt?: string;
  ogType?: "website" | "article";
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
};

const defaultDescription =
  "无需登录、可离线、在浏览器本地运行的 JSON、CSV、Base64、正则测试、二维码、图片压缩等十四项工具与六个组合工作流。";
const {
  title = "Online Tools Hub — 隐私优先的在线工具箱",
  description = defaultDescription,
  noindex = false,
  pageClass,
  canonical: canonicalOverride,
  keywords = [],
  imageAlt = "Online Tools Hub：隐私优先的浏览器在线工具箱",
  ogType = "website",
  structuredData = [],
} = Astro.props;

const siteOrigin = Astro.site ?? new URL(Astro.url.origin);
const canonical =
  canonicalOverride === false
    ? undefined
    : new URL(canonicalOverride ?? Astro.url.pathname, siteOrigin);
const homeUrl = new URL(import.meta.env.BASE_URL, siteOrigin);
const socialImage = new URL(pathFor("/og-image.png"), siteOrigin);
const additionalSchemas = Array.isArray(structuredData)
  ? structuredData
  : [structuredData];
const schemaGraph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${homeUrl.href}#website`,
      name: "Online Tools Hub",
      alternateName: "在线工具中心",
      url: homeUrl.href,
      description: defaultDescription,
      inLanguage: "zh-CN",
      isAccessibleForFree: true,
    },
    ...additionalSchemas,
  ],
};
const serializedSchema = JSON.stringify(schemaGraph).replace(/</gu, "\\u003c");
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {
      keywords.length > 0 && (
        <meta name="keywords" content={keywords.join(", ")} />
      )
    }
    <meta name="author" content="Online Tools Hub" />
    <meta name="referrer" content="no-referrer" />
    <meta
      name="theme-color"
      content="#f6f8fc"
      media="(prefers-color-scheme: light)"
      data-theme-color="light"
    />
    <meta
      name="theme-color"
      content="#0b1020"
      media="(prefers-color-scheme: dark)"
      data-theme-color="dark"
    />
    <meta
      name="robots"
      content={noindex
        ? "noindex, nofollow"
        : "index, follow, max-image-preview:large, max-snippet:-1"}
    />
    {canonical && <link rel="canonical" href={canonical} />}
    {canonical && <link rel="alternate" hreflang="zh-CN" href={canonical} />}
    {
      canonical && (
        <link rel="alternate" hreflang="x-default" href={canonical} />
      )
    }
    <link rel="sitemap" type="application/xml" href={pathFor("/sitemap.xml")} />
    <link rel="icon" href={pathFor("/favicon.svg")} type="image/svg+xml" />
    <link rel="manifest" href={pathFor("/manifest.webmanifest")} />
    <link
      rel="alternate"
      type="application/json"
      title="Privacy manifest"
      href={pathFor("/privacy-manifest.json")}
    />
    <link rel="apple-touch-icon" href={pathFor("/icons/app-icon-192.png")} />

    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:site_name" content="Online Tools Hub" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <title>{title}</title>
  </head>
  <body>
    <!--
      Astro emits the meta CSP at the end of <head>. Runtime-only styles must
      follow it, so this named slot is deliberately the first body resource.
    -->
    <slot name="pageStyles" />
    <script is:inline>
      try {
        const theme = localStorage.getItem("online-tools-hub:theme");
        if (theme === "light" || theme === "dark") {
          document.documentElement.dataset.theme = theme;
        }
      } catch {
        // The system preference remains active when storage is unavailable.
      }
    </script>
    <script type="application/ld+json" is:inline set:html={serializedSchema} />
    <a class="skip-link" href="#main-content">跳到主要内容</a>
    <SiteHeader />
    <main id="main-content" class={pageClass}>
      <slot />
    </main>
    <SiteFooter />
    <PwaManager client:load baseUrl={import.meta.env.BASE_URL} />
  </body>
</html>
