---
import LocalBadge from "../../components/LocalBadge.astro";
import WorkflowTemplateCard from "../../components/WorkflowTemplateCard.astro";
import WorkflowStudio from "../../components/workflows/WorkflowStudio";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { pathFor } from "../../lib/tool-registry";
import {
  getWorkflowContentStaticPaths,
  workflowContents,
  type WorkflowContentDefinition,
} from "../../lib/workflow-content";

export function getStaticPaths() {
  return getWorkflowContentStaticPaths();
}

const { workflow } = Astro.props as { workflow: WorkflowContentDefinition };
const origin = Astro.site ?? new URL(Astro.url.origin);
const pageUrl = new URL(pathFor(`/workflows/${workflow.slug}/`), origin).href;
const workflowsUrl = new URL(pathFor("/workflows/"), origin).href;
const privacyUrl = new URL(pathFor("/privacy/"), origin).href;
const relatedWorkflows = workflowContents
  .filter((candidate) => candidate.id !== workflow.id)
  .slice(0, 2);
const structuredData = [
  {
    "@type": "SoftwareApplication",
    "@id": `${pageUrl}#application`,
    name: workflow.title,
    description: workflow.description,
    url: pageUrl,
    applicationCategory: "DeveloperApplication",
    applicationSubCategory: "Local workflow",
    operatingSystem: "Any",
    browserRequirements:
      "Requires a modern browser with JavaScript, Web Worker and Web Crypto support.",
    inLanguage: "zh-CN",
    isAccessibleForFree: true,
    privacyPolicy: privacyUrl,
    featureList: workflow.steps.map((step) => step.title),
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "CNY",
    },
  },
  {
    "@type": "HowTo",
    "@id": `${pageUrl}#howto`,
    name: `如何使用“${workflow.title}”本地工作流`,
    description: workflow.summary,
    totalTime: `PT${workflow.durationMinutes}M`,
    inLanguage: "zh-CN",
    step: workflow.steps.map((step, index) => ({
      "@type": "HowToStep",
      position: index + 1,
      name: step.title,
      text: step.description,
      url: `${pageUrl}#workflow-step-${index + 1}`,
    })),
  },
  {
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "首页",
        item: new URL(pathFor("/"), origin).href,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "本地工作流",
        item: workflowsUrl,
      },
      {
        "@type": "ListItem",
        position: 3,
        name: workflow.title,
        item: pageUrl,
      },
    ],
  },
];
---

<BaseLayout
  title={`${workflow.title}：${workflow.eyebrow}本地工作流 — Online Tools Hub`}
  description={workflow.description}
  keywords={[...workflow.keywords]}
  structuredData={structuredData}
>
  <article class="container page-shell workflow-detail">
    <nav class="breadcrumbs" aria-label="面包屑">
      <a href={pathFor("/")}>首页</a>
      <span aria-hidden="true">/</span>
      <a href={pathFor("/workflows/")}>本地工作流</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">{workflow.title}</span>
    </nav>

    <header class="workflow-detail__hero">
      <span class="workflow-detail__mark" aria-hidden="true"
        >{workflow.mark}</span
      >
      <div>
        <p class="eyebrow">{workflow.eyebrow} · {workflow.steps.length} 步</p>
        <h1>{workflow.title}</h1>
        <p>{workflow.summary}</p>
        <div class="workflow-detail__badges">
          <LocalBadge />
          <span>零上传</span>
          <span>配方不含正文</span>
        </div>
      </div>
    </header>

    <aside class="workflow-detail__input-boundary">
      <div>
        <strong>输入</strong><span>{workflow.inputLabel}</span>
      </div>
      <div>
        <strong>最终结果</strong><span>{workflow.outputLabel}</span>
      </div>
      <p>{workflow.inputHelp}</p>
    </aside>

    <section
      id="workflow-studio"
      class="workflow-detail__studio"
      aria-labelledby="workflow-studio-title"
    >
      <div class="workflow-detail__section-heading">
        <div>
          <p class="eyebrow">Workflow Studio</p>
          <h2 id="workflow-studio-title">输入一次，逐步查看本地结果</h2>
        </div>
        <p>取消或清空会释放当前运行的内存数据。</p>
      </div>
      <WorkflowStudio
        client:load
        templateId={workflow.id}
        baseUrl={import.meta.env.BASE_URL}
      />
    </section>

    <div class="workflow-detail__explain">
      <section aria-labelledby="workflow-steps-title">
        <p class="eyebrow">执行顺序</p>
        <h2 id="workflow-steps-title">这条配方会做什么</h2>
        <ol class="workflow-detail__steps">
          {
            workflow.steps.map((step, index) => (
              <li id={`workflow-step-${index + 1}`}>
                <span aria-hidden="true">
                  {String(index + 1).padStart(2, "0")}
                </span>
                <div>
                  <h3>{step.title}</h3>
                  <p>{step.description}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </section>

      <aside class="workflow-detail__privacy" aria-labelledby="privacy-title">
        <p class="eyebrow">数据生命周期</p>
        <h2 id="privacy-title">正文只在当前标签页内存</h2>
        <ul>
          <li>运行前先校验步骤、选项与相邻数据类型；</li>
          <li>界面状态只引用随机 payload ID，不把正文写进 URL；</li>
          <li>配方导入导出不包含输入、结果、文件名或内容哈希；</li>
          <li>取消、清空和离开页面会统一释放中间结果。</li>
        </ul>
        <a href={pathFor("/privacy/")}>阅读完整隐私说明 →</a>
      </aside>
    </div>

    <section class="workflow-detail__result" aria-labelledby="result-title">
      <div>
        <p class="eyebrow">结果边界</p>
        <h2 id="result-title">完成后你会得到什么</h2>
      </div>
      <div>
        <p>{workflow.resultDescription}</p>
        <ul>
          {workflow.notices.map((notice) => <li>{notice}</li>)}
        </ul>
      </div>
    </section>

    <section
      class="workflow-detail__more"
      aria-labelledby="more-workflows-title"
    >
      <div class="section-heading section-heading--row">
        <div>
          <p class="eyebrow">继续处理</p>
          <h2 id="more-workflows-title">其他本地工作流</h2>
        </div>
        <a class="text-link" href={pathFor("/workflows/")}
          >查看全部 <span aria-hidden="true">→</span></a
        >
      </div>
      <div class="workflow-detail__more-grid">
        {
          relatedWorkflows.map((candidate) => (
            <WorkflowTemplateCard workflow={candidate} headingLevel="h3" />
          ))
        }
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .workflow-detail__hero {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: start;
    max-width: 62rem;
    gap: 1.15rem;
    margin-bottom: 1.5rem;
  }

  .workflow-detail__mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 4.25rem;
    height: 4.25rem;
    border: 1px solid color-mix(in srgb, var(--brand) 28%, var(--line));
    border-radius: 1.1rem;
    background: var(--brand-soft);
    color: var(--brand-ink);
    font-size: 0.88rem;
    font-weight: 900;
  }

  .workflow-detail__hero h1 {
    margin-block: 0.4rem 0.65rem;
    font-size: clamp(2rem, 5vw, 3.35rem);
  }

  .workflow-detail__hero > div > p:not(.eyebrow) {
    max-width: 48rem;
    font-size: clamp(1rem, 2vw, 1.12rem);
  }

  .workflow-detail__badges {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.55rem;
    margin-top: 1rem;
  }

  .workflow-detail__badges > span:not(.local-badge) {
    display: inline-flex;
    align-items: center;
    min-height: 2.35rem;
    padding: 0.45rem 0.75rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--surface-subtle);
    color: var(--ink-soft);
    font-size: 0.76rem;
    font-weight: 700;
  }

  .workflow-detail__input-boundary {
    display: grid;
    grid-template-columns: minmax(10rem, 0.4fr) minmax(12rem, 0.6fr) minmax(
        16rem,
        1fr
      );
    gap: 1rem;
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
    padding: 1rem 1.1rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--surface-subtle);
  }

  .workflow-detail__input-boundary > div {
    display: grid;
    gap: 0.2rem;
  }

  .workflow-detail__input-boundary strong {
    color: var(--muted);
    font-size: 0.72rem;
    text-transform: uppercase;
  }

  .workflow-detail__input-boundary span,
  .workflow-detail__input-boundary p {
    font-size: 0.82rem;
  }

  .workflow-detail__studio {
    scroll-margin-top: 7rem;
  }

  .workflow-detail__section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 1rem;
  }

  .workflow-detail__section-heading h2,
  .workflow-detail__explain h2,
  .workflow-detail__result h2 {
    margin-top: 0.35rem;
    font-size: clamp(1.35rem, 3vw, 1.8rem);
  }

  .workflow-detail__section-heading > p {
    max-width: 25rem;
    font-size: 0.82rem;
    text-align: right;
  }

  .workflow-detail__explain {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(18rem, 0.75fr);
    align-items: start;
    gap: clamp(1.5rem, 5vw, 4rem);
    margin-top: clamp(3rem, 7vw, 5rem);
  }

  .workflow-detail__steps {
    display: grid;
    gap: 0;
    margin-top: 1.25rem;
    padding: 0;
    list-style: none;
  }

  .workflow-detail__steps li {
    display: grid;
    grid-template-columns: 2.5rem minmax(0, 1fr);
    gap: 0.9rem;
    padding: 1rem 0;
    border-top: 1px solid var(--line);
    scroll-margin-top: 7rem;
  }

  .workflow-detail__steps li > span {
    color: var(--brand);
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0.08em;
  }

  .workflow-detail__steps h3 {
    margin-bottom: 0.25rem;
    font-size: 1rem;
  }

  .workflow-detail__steps p,
  .workflow-detail__privacy,
  .workflow-detail__result {
    font-size: 0.85rem;
  }

  .workflow-detail__privacy {
    padding: 1.2rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--surface-subtle);
  }

  .workflow-detail__privacy h2 {
    font-size: 1.25rem;
  }

  .workflow-detail__privacy ul,
  .workflow-detail__result ul {
    display: grid;
    gap: 0.55rem;
    margin-block: 1rem;
    padding-left: 1.15rem;
    color: var(--muted);
  }

  .workflow-detail__privacy a {
    color: var(--brand);
    font-weight: 750;
  }

  .workflow-detail__result {
    display: grid;
    grid-template-columns: minmax(14rem, 0.65fr) minmax(0, 1.35fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    margin-top: clamp(3rem, 7vw, 5rem);
    padding: clamp(1.2rem, 4vw, 2rem);
    border: 1px solid var(--line);
    border-left: 0.25rem solid var(--brand);
    border-radius: var(--radius-lg);
    background: var(--surface);
  }

  .workflow-detail__result ul {
    margin-bottom: 0;
  }

  .workflow-detail__more {
    margin-top: clamp(3rem, 7vw, 5rem);
  }

  .workflow-detail__more-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  @media (max-width: 800px) {
    .workflow-detail__input-boundary,
    .workflow-detail__explain,
    .workflow-detail__result {
      grid-template-columns: 1fr;
    }

    .workflow-detail__input-boundary > div + div {
      padding-top: 0.75rem;
      border-top: 1px solid var(--line);
    }
  }

  @media (max-width: 720px) {
    .workflow-detail__hero {
      grid-template-columns: 1fr;
    }

    .workflow-detail__mark {
      width: 3.7rem;
      height: 3.7rem;
    }

    .workflow-detail__section-heading {
      align-items: start;
      flex-direction: column;
      gap: 0.6rem;
    }

    .workflow-detail__section-heading > p {
      text-align: left;
    }

    .workflow-detail__more-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
