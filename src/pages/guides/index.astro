---
import BaseLayout from "../../layouts/BaseLayout.astro";
import GuideCard from "../../components/GuideCard.astro";
import { guides } from "../../lib/guide-content";
import { pathFor } from "../../lib/tool-registry";

const origin = Astro.site ?? new URL(Astro.url.origin);
const pageUrl = new URL(pathFor("/guides/"), origin).href;
const structuredData = [
  {
    "@type": "CollectionPage",
    name: "知识中心 — Online Tools Hub",
    url: pageUrl,
    description:
      "关于数据格式、编码、文件完整性、图片优化与浏览器本地隐私的实用指南。",
    inLanguage: "zh-CN",
  },
  {
    "@type": "ItemList",
    name: "实用数据与开发指南",
    numberOfItems: guides.length,
    itemListElement: guides.map((guide, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: guide.title,
      url: new URL(pathFor(`/guides/${guide.slug}/`), origin).href,
    })),
  },
];
---

<BaseLayout
  title="知识中心：数据、编码与隐私实用指南 — Online Tools Hub"
  description="阅读 Base64、JWT、SHA-256、CSV、JSON、图片压缩、YAML、URL 参数与浏览器本地隐私指南。"
  keywords={["开发者指南", "数据转换", "在线工具教程", "浏览器本地处理"]}
  structuredData={structuredData}
>
  <div class="container page-shell guide-index">
    <header class="page-intro">
      <p class="eyebrow">知识中心</p>
      <h1>工具解决眼前问题，指南讲清背后的边界</h1>
      <p>
        从数据格式到凭据安全，每篇内容都给出可执行的检查清单，并直接连接到对应的本地工具。
      </p>
    </header>

    <div class="guide-grid" aria-label="全部指南">
      {guides.map((guide) => <GuideCard guide={guide} />)}
    </div>
  </div>
</BaseLayout>
