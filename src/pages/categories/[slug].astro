---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ToolCard from "../../components/ToolCard.astro";
import {
  getCategoryStaticPaths,
  getToolsByCategory,
  pathFor,
  type CategoryDefinition,
} from "../../lib/tool-registry";

export function getStaticPaths() {
  return getCategoryStaticPaths();
}

const { category } = Astro.props as { category: CategoryDefinition };
const categoryTools = getToolsByCategory(category.slug);
const origin = Astro.site ?? new URL(Astro.url.origin);
const categoryUrl = new URL(pathFor(`/categories/${category.slug}/`), origin)
  .href;
const structuredData = {
  "@type": "CollectionPage",
  name: category.title,
  url: categoryUrl,
  description: category.description,
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: categoryTools.length,
    itemListElement: categoryTools.map((tool, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: tool.title,
      url: new URL(pathFor(`/tools/${tool.slug}/`), origin).href,
    })),
  },
};
---

<BaseLayout
  title={`${category.title} — Online Tools Hub`}
  description={category.description}
  keywords={[category.title, "在线工具", "浏览器本地处理"]}
  noindex={categoryTools.length === 0}
  structuredData={structuredData}
>
  <div class="container page-shell">
    <nav class="breadcrumbs" aria-label="面包屑">
      <a href={pathFor("/")}>首页</a><span aria-hidden="true">/</span><a
        href={pathFor("/categories/")}>分类</a
      ><span aria-hidden="true">/</span><span aria-current="page"
        >{category.title}</span
      >
    </nav>
    <header class="page-intro category-intro">
      <span class="tool-mark tool-mark--large" aria-hidden="true"
        >{category.mark}</span
      >
      <div>
        <p class="eyebrow">工具分类</p><h1>{category.title}</h1><p>
          {category.description}
        </p>
      </div>
    </header>
    {
      categoryTools.length > 0 ? (
        <div class="tool-grid">
          {categoryTools.map((tool) => (
            <ToolCard tool={tool} />
          ))}
        </div>
      ) : (
        <section class="empty-state">
          <>
            <span aria-hidden="true">＋</span>
            <h2>这个分类在路线图中</h2>
          </>
          <p>我们会先维护好当前六个工具，再根据真实需求增加此分类的能力。</p>
          <a class="button button--secondary" href={pathFor("/tools/")}>
            查看当前工具
          </a>
        </section>
      )
    }
  </div>
</BaseLayout>
