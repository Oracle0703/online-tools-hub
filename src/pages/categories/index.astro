---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CategoryCard from "../../components/CategoryCard.astro";
import { categories, pathFor } from "../../lib/tool-registry";

const origin = Astro.site ?? new URL(Astro.url.origin);
const structuredData = {
  "@type": "CollectionPage",
  name: "在线工具分类",
  url: new URL(pathFor("/categories/"), origin).href,
  description: "按格式化、编解码、图片、时间与标识符等任务浏览在线工具。",
};
---

<BaseLayout
  title="工具分类 — Online Tools Hub"
  description="按格式化、编解码、图片、文本、时间与标识符等任务浏览在线工具。"
  keywords={["工具分类", "格式化工具", "编码工具", "图片压缩工具", "时间工具"]}
  structuredData={structuredData}
>
  <div class="container page-shell">
    <header class="page-intro">
      <p class="eyebrow">工具分类</p>
      <h1>从任务出发，而不是从术语出发</h1>
      <p>
        已上线和规划中的工具都归入稳定分类，方便找到相关能力，也让站点长期扩展时仍然清楚。
      </p>
    </header>
    <div class="category-list">
      {categories.map((category) => <CategoryCard category={category} />)}
    </div>
  </div>
</BaseLayout>
