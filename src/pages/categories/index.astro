---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CategoryCard from "../../components/CategoryCard.astro";
import { categories, enabledTools, pathFor } from "../../lib/tool-registry";

const activeCategories = categories.filter((category) =>
  enabledTools.some((tool) => tool.category === category.slug),
);
const roadmapCategories = categories.filter(
  (category) => !enabledTools.some((tool) => tool.category === category.slug),
);

const origin = Astro.site ?? new URL(Astro.url.origin);
const structuredData = {
  "@type": "CollectionPage",
  name: "在线工具分类",
  url: new URL(pathFor("/categories/"), origin).href,
  description:
    "按格式化、编解码、文本、图片、时间、标识符与安全校验等任务浏览在线工具。",
};
---

<BaseLayout
  title="工具分类 — Online Tools Hub"
  description="按格式化、编解码、图片、文本、时间与标识符等任务浏览在线工具。"
  keywords={[
    "工具分类",
    "格式化工具",
    "编码工具",
    "文本对比",
    "图片压缩工具",
    "哈希工具",
    "时间工具",
  ]}
  structuredData={structuredData}
>
  <div class="container page-shell">
    <header class="page-intro">
      <p class="eyebrow">工具分类</p>
      <h1>从任务出发，而不是从术语出发</h1>
      <p>
        已上线和规划中的工具都归入稳定分类，方便找到相关能力，也让站点长期扩展时仍然清楚。
      </p>
    </header>
    <div class="category-list">
      {activeCategories.map((category) => <CategoryCard category={category} />)}
    </div>
    {
      roadmapCategories.length > 0 && (
        <section class="roadmap-note" aria-labelledby="roadmap-title">
          <span aria-hidden="true">＋</span>
          <div>
            <p class="eyebrow">路线图</p>
            <h2 id="roadmap-title">更多工具会按需加入</h2>
            <p>
              正在规划：
              {roadmapCategories.map((category) => category.title).join("、")}。
              我们会先把现有工具维护可靠，再逐步扩展。
            </p>
          </div>
        </section>
      )
    }
  </div>
</BaseLayout>
