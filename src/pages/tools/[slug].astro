---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ToolShell from "../../components/ToolShell.astro";
import { currentRelease, getToolUseCases } from "../../lib/experience-content";
import { getToolPageContent } from "../../lib/tool-content";
import {
  getToolStaticPaths,
  getCategoryBySlug,
  pathFor,
  type ToolDefinition,
} from "../../lib/tool-registry";
import { loadToolRuntime } from "../../lib/tool-runtime";

export function getStaticPaths() {
  return getToolStaticPaths();
}

const { tool } = Astro.props as { tool: ToolDefinition };
const { Component: ToolRuntime, stylesheet } = await loadToolRuntime(tool.slug);
const category = getCategoryBySlug(tool.category);
const content = getToolPageContent(tool.slug);
const useCases = getToolUseCases(tool.slug);
const origin = Astro.site ?? new URL(Astro.url.origin);
const pageUrl = new URL(pathFor(`/tools/${tool.slug}/`), origin).href;
const socialImageUrl = new URL(pathFor("/og-image.png"), origin).href;
const structuredData = [
  {
    "@type": "WebApplication",
    "@id": `${pageUrl}#application`,
    name: tool.title,
    url: pageUrl,
    description: tool.description,
    applicationCategory:
      tool.slug === "image-compressor"
        ? "MultimediaApplication"
        : "DeveloperApplication",
    applicationSubCategory: category?.title,
    operatingSystem: "Any",
    browserRequirements: "需要支持 JavaScript 的现代浏览器",
    inLanguage: "zh-CN",
    isAccessibleForFree: true,
    image: socialImageUrl,
    softwareVersion: currentRelease.version,
    featureList: [
      ...content.steps.map((step) => `${step.title}：${step.description}`),
      ...useCases.map((useCase) => `${useCase.title}：${useCase.outcome}`),
    ],
    offers: {
      "@type": "Offer",
      price: 0,
    },
  },
  {
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "首页",
        item: new URL(pathFor("/"), origin).href,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "全部工具",
        item: new URL(pathFor("/tools/"), origin).href,
      },
      {
        "@type": "ListItem",
        position: 3,
        name: category?.title ?? "工具分类",
        item: new URL(pathFor(`/categories/${category?.slug ?? ""}/`), origin)
          .href,
      },
      {
        "@type": "ListItem",
        position: 4,
        name: tool.title,
        item: pageUrl,
      },
    ],
  },
  {
    "@type": "FAQPage",
    mainEntity: content.faqs.map((faq) => ({
      "@type": "Question",
      name: faq.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: faq.answer,
      },
    })),
  },
];
---

<BaseLayout
  title={`${tool.title} — Online Tools Hub`}
  description={tool.description}
  keywords={[...tool.keywords, "在线工具", "浏览器本地处理"]}
  structuredData={structuredData}
>
  <Fragment slot="pageStyles">
    <link rel="stylesheet" href={stylesheet} />
  </Fragment>
  <ToolShell tool={tool}>
    <ToolRuntime slot="workspace" />
  </ToolShell>
</BaseLayout>
