---
import BaseLayout from "../layouts/BaseLayout.astro";
import CategoryCard from "../components/CategoryCard.astro";
import ToolDirectory from "../components/ToolDirectory";
import LocalBadge from "../components/LocalBadge.astro";
import {
  categories,
  enabledTools,
  pathFor,
  toToolSummary,
} from "../lib/tool-registry";

const toolSummaries = enabledTools.map(toToolSummary);
const activeCategories = categories.filter((category) =>
  enabledTools.some((tool) => tool.category === category.slug),
);
const origin = Astro.site ?? new URL(Astro.url.origin);
const structuredData = [
  {
    "@type": "WebPage",
    name: "Online Tools Hub — 隐私优先的在线工具箱",
    url: new URL(pathFor("/"), origin).href,
    description:
      "无需登录、在浏览器本地运行的图片压缩、JSON、Base64、URL、时间戳和 UUID 工具。",
    inLanguage: "zh-CN",
  },
  {
    "@type": "ItemList",
    name: "可用在线工具",
    numberOfItems: enabledTools.length,
    itemListElement: enabledTools.map((tool, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: tool.title,
      url: new URL(pathFor(`/tools/${tool.slug}/`), origin).href,
    })),
  },
];
---

<BaseLayout
  keywords={[
    "在线工具",
    "JSON 格式化",
    "Base64 编解码",
    "URL 编码",
    "Unix 时间戳",
    "UUID 生成器",
    "图片压缩",
    "PNG 压缩",
    "JPEG 压缩",
    "WebP 压缩",
  ]}
  structuredData={structuredData}
>
  <div class="container page-shell">
    <section class="home-hero" aria-labelledby="home-title">
      <div class="home-hero__copy">
        <LocalBadge />
        <p class="eyebrow">Online Tools Hub</p>
        <h1 id="home-title">处理数据，<br /><span>不交出数据。</span></h1>
        <p>
          一组安静、可靠的开发者工具。无需登录，没有广告，文本和图片只在你的浏览器中处理。
        </p>
        <div class="home-hero__actions">
          <a class="button button--primary" href={pathFor("/tools/")}
            >浏览全部工具</a
          >
          <a class="button button--secondary" href={pathFor("/privacy/")}
            >了解隐私原则</a
          >
        </div>
      </div>
      <aside class="promise-card" aria-label="隐私承诺">
        <p class="eyebrow">我们的默认设置</p>
        <ul>
          <li>
            <span>01</span><div>
              <strong>不上传</strong><p>转换不经过应用服务器。</p>
            </div>
          </li>
          <li>
            <span>02</span><div>
              <strong>不留存</strong><p>刷新后不会恢复输入。</p>
            </div>
          </li>
          <li>
            <span>03</span><div>
              <strong>不追踪</strong><p>不记录输入、输出或剪贴板。</p>
            </div>
          </li>
        </ul>
      </aside>
    </section>

    <section class="home-section" aria-labelledby="popular-title">
      <div class="section-heading section-heading--row">
        <div>
          <p class="eyebrow">快速开始</p>
          <h2 id="popular-title">找到需要的工具</h2>
        </div>
        <a class="text-link" href={pathFor("/tools/")}
          >完整目录 <span aria-hidden="true">→</span></a
        >
      </div>
      <ToolDirectory
        client:visible
        tools={toolSummaries}
        categories={categories}
        baseUrl={import.meta.env.BASE_URL}
        compact
      />
    </section>

    <section
      class="home-section category-showcase"
      aria-labelledby="category-title"
    >
      <div class="section-heading">
        <p class="eyebrow">按任务探索</p>
        <h2 id="category-title">清晰分类，不做工具迷宫</h2>
        <p>每个页面只解决一个明确问题，并使用一致的输入、输出和错误提示。</p>
      </div>
      <div class="category-list">
        {
          activeCategories.map((category) => (
            <CategoryCard category={category} />
          ))
        }
      </div>
    </section>

    <section class="home-section" aria-labelledby="principles-title">
      <div class="section-heading">
        <p class="eyebrow">产品原则</p>
        <h2 id="principles-title">少一点干扰，多一点确定</h2>
      </div>
      <div class="info-card-grid">
        <article class="info-card">
          <span class="info-card__number">01</span><h3>打开即用</h3><p>
            不要求注册、订阅或安装，移动设备和键盘操作同样可用。
          </p>
        </article>
        <article class="info-card">
          <span class="info-card__number">02</span><h3>边界说清楚</h3><p>
            每个工具都标明处理位置、输入限制和容易误用的边界。
          </p>
        </article>
        <article class="info-card">
          <span class="info-card__number">03</span><h3>开源可验证</h3><p>
            架构、实现与变更公开，隐私承诺可以被测试而不是只能被相信。
          </p>
        </article>
      </div>
    </section>
  </div>
</BaseLayout>
