---
import BaseLayout from "../layouts/BaseLayout.astro";
import CategoryCard from "../components/CategoryCard.astro";
import HomeLivePreview from "../components/HomeLivePreview";
import HomeToolMemory from "../components/HomeToolMemory";
import RecentUpdates from "../components/RecentUpdates.astro";
import TaskRecipes from "../components/TaskRecipes.astro";
import ToolDirectory from "../components/ToolDirectory";
import LocalBadge from "../components/LocalBadge.astro";
import { homeTaskRecipes, recentReleases } from "../lib/experience-content";
import {
  categories,
  enabledTools,
  pathFor,
  toToolSummary,
} from "../lib/tool-registry";

const toolSummaries = enabledTools.map(toToolSummary);
const activeCategories = categories.filter((category) =>
  enabledTools.some((tool) => tool.category === category.slug),
);
const origin = Astro.site ?? new URL(Astro.url.origin);
const structuredData = [
  {
    "@type": "WebPage",
    name: "Online Tools Hub — 隐私优先的在线工具箱",
    url: new URL(pathFor("/"), origin).href,
    description:
      "无需登录、在浏览器本地运行的图片压缩、JSON、Base64、URL、时间戳和 UUID 工具。",
    inLanguage: "zh-CN",
  },
  {
    "@type": "ItemList",
    name: "可用在线工具",
    numberOfItems: enabledTools.length,
    itemListElement: enabledTools.map((tool, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: tool.title,
      url: new URL(pathFor(`/tools/${tool.slug}/`), origin).href,
    })),
  },
];
---

<BaseLayout
  keywords={[
    "在线工具",
    "JSON 格式化",
    "Base64 编解码",
    "URL 编码",
    "Unix 时间戳",
    "UUID 生成器",
    "图片压缩",
    "PNG 压缩",
    "JPEG 压缩",
    "WebP 压缩",
  ]}
  structuredData={structuredData}
>
  <div class="container page-shell home-page">
    <section class="home-hero" aria-labelledby="home-title">
      <div class="home-hero__copy">
        <LocalBadge />
        <p class="eyebrow">Online Tools Hub</p>
        <h1 id="home-title">处理数据，<br /><span>不交出数据。</span></h1>
        <p>
          一组安静、可靠的开发者工具。无需登录，没有广告，文本和图片只在你的浏览器中处理。
        </p>
        <div class="home-hero__actions">
          <a class="button button--primary" href={pathFor("/tools/")}
            >浏览全部工具</a
          >
          <a class="button button--secondary" href={pathFor("/privacy/")}
            >了解隐私原则</a
          >
        </div>
        <dl class="home-hero__proof" aria-label="站点能力概览">
          <div><dt>{enabledTools.length}</dt><dd>个可用工具</dd></div>
          <div><dt>100%</dt><dd>浏览器本地处理</dd></div>
          <div><dt>0</dt><dd>项内容追踪</dd></div>
        </dl>
      </div>
      <HomeLivePreview client:load baseUrl={import.meta.env.BASE_URL} />
    </section>

    <div class="home-section home-memory-section">
      <HomeToolMemory
        client:load
        tools={toolSummaries}
        baseUrl={import.meta.env.BASE_URL}
      />
    </div>

    <div class="home-section">
      <TaskRecipes
        recipes={homeTaskRecipes}
        eyebrow="常见任务"
        title="从问题出发，而不是从工具名出发"
        description="选择一个与你当前情况接近的任务，先理解处理结果和注意事项，再进入完整工具。"
        headingId="home-task-recipes-title"
        density="compact"
      />
    </div>

    <section class="home-section" aria-labelledby="popular-title">
      <div class="section-heading section-heading--row">
        <div>
          <p class="eyebrow">快速开始</p>
          <h2 id="popular-title">常用工具，打开即用</h2>
        </div>
        <a class="text-link" href={pathFor("/tools/")}
          >完整目录 <span aria-hidden="true">→</span></a
        >
      </div>
      <ToolDirectory
        client:visible
        tools={toolSummaries}
        categories={categories}
        baseUrl={import.meta.env.BASE_URL}
        compact
      />
    </section>

    <div class="home-section">
      <RecentUpdates
        releases={recentReleases}
        headingId="home-recent-updates-title"
      />
    </div>

    <section
      class="home-section category-showcase"
      aria-labelledby="category-title"
    >
      <div class="section-heading">
        <p class="eyebrow">按任务探索</p>
        <h2 id="category-title">清晰分类，不做工具迷宫</h2>
        <p>每个页面只解决一个明确问题，并使用一致的输入、输出和错误提示。</p>
      </div>
      <div class="category-list">
        {
          activeCategories.map((category) => (
            <CategoryCard category={category} />
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
