---
import BaseLayout from "../layouts/BaseLayout.astro";
import { pathFor } from "../lib/tool-registry";

const origin = Astro.site ?? new URL(Astro.url.origin);
const structuredData = {
  "@type": "AboutPage",
  name: "关于 Online Tools Hub",
  url: new URL(pathFor("/about/"), origin).href,
  description:
    "提供十二个本地工具与知识指南的开源、隐私优先、无需登录综合在线工具站。",
  inLanguage: "zh-CN",
};
---

<BaseLayout
  title="关于项目 — Online Tools Hub"
  description="Online Tools Hub 提供十二个浏览器本地工具与知识指南，是一个开源、隐私优先、无需登录的综合在线工具站。"
  structuredData={structuredData}
>
  <div class="container page-shell">
    <header class="page-intro">
      <p class="eyebrow">关于项目</p>
      <h1>让临时工具也值得信任</h1>
      <p>
        Online Tools Hub
        面向开发者、学生和日常办公用户：打开即用，少量工具先做到可靠，再稳定扩展。
      </p>
    </header>
    <section class="info-card-grid" aria-label="项目原则">
      <article class="info-card">
        <span class="info-card__number">01</span><h2>本地优先</h2><p>
          能在浏览器完成的处理绝不上传，并通过自动化测试持续验证这条承诺。
        </p>
      </article>
      <article class="info-card">
        <span class="info-card__number">02</span><h2>质量优先</h2><p>
          不追求工具数量，优先处理中文、大整数、时区、图片格式、复杂文本和错误定位等边界。
        </p>
      </article>
      <article class="info-card">
        <span class="info-card__number">03</span><h2>一致优先</h2><p>
          工具共享相同页面结构、操作顺序、错误语言和无障碍标准。
        </p>
      </article>
    </section>
    <section class="content-section content-grid">
      <div><p class="eyebrow">当前范围</p><h2>十二个高频工具</h2></div>
      <div class="prose">
        <p>
          当前提供 JSON 格式化、Base64 编解码、URL 编解码、Unix 时间戳转换、UUID
          v4 生成、图片压缩、文本差异、SHA 哈希、YAML / JSON 互转和 JWT
          声明检查，以及 CSV / JSON 互转和 URL
          查询参数编辑。每项能力都需要通过功能、隐私、移动端与无障碍验收。
        </p><p>
          0.9.0
          新增本地智能识别、覆盖工具/指南/任务的全站搜索，以及用户主动触发的安全跨工具接力。项目采用
          Astro、React 和 TypeScript 构建为静态站点，默认发布到 GitHub
          Pages；工具输入不会因此进入服务器、网址或离线缓存。
        </p>
      </div>
    </section>
    <section class="notice-card">
      <span aria-hidden="true">↗</span>
      <div>
        <h2>参与开源项目</h2><p>
          可以在 GitHub 查看源代码、提交问题或参与讨论。
        </p><p>
          <a
            class="text-link"
            href="https://github.com/Oracle0703/online-tools-hub"
            target="_blank"
            rel="noreferrer"
            >打开 GitHub 仓库 <span aria-hidden="true">→</span></a
          > · <a class="text-link" href={pathFor("/changelog/")}>查看更新日志</a
          >
        </p>
      </div>
    </section>
  </div>
</BaseLayout>
