---
import BaseLayout from "../layouts/BaseLayout.astro";
import { pathFor } from "../lib/tool-registry";

const origin = Astro.site ?? new URL(Astro.url.origin);
const structuredData = {
  "@type": "CollectionPage",
  name: "Online Tools Hub 更新日志",
  url: new URL(pathFor("/changelog/"), origin).href,
  description: "Online Tools Hub 的新工具、修复与隐私行为变更记录。",
  inLanguage: "zh-CN",
};
---

<BaseLayout
  title="更新日志 — Online Tools Hub"
  description="查看 Online Tools Hub 的新工具、修复和隐私相关行为变更。"
  structuredData={structuredData}
>
  <div class="container page-shell">
    <header class="page-intro">
      <p class="eyebrow">更新日志</p><h1>每一次变化，都说清楚</h1><p>
        这里记录新工具、问题修复，以及任何可能影响隐私或使用方式的行为变化。
      </p>
    </header>
    <div class="timeline">
      <article class="timeline-item">
        <time datetime="2026-07-19">2026 年 7 月 19 日</time><div>
          <p class="eyebrow">0.4.0 · 本地图片处理</p><h2>
            图片压缩与格式转换
          </h2><ul>
            <li>上线 JPEG、PNG、WebP 批量压缩与格式转换；</li><li>
              支持调整质量与最长边，并单独下载或打包取回结果；
            </li><li>
              文件只在浏览器内存处理，补充 Blob URL、元数据和动画格式边界说明；
            </li><li>
              采用浏览器编码与 PNG 色彩量化，不宣称复现第三方专有算法；
            </li><li>扩展为六个工具，并同步更新移动端目录、SEO 和站点地图。</li>
          </ul>
        </div>
      </article>
      <article class="timeline-item">
        <time datetime="2026-07-19">2026 年 7 月 19 日</time><div>
          <p class="eyebrow">0.3.0 · MVP 工具集</p><h2>
            四个新工具与全站移动端、SEO 完善
          </h2><ul>
            <li>上线 Base64 / Base64URL 与 URL 编解码工具；</li><li>
              上线 Unix 时间戳转换与 UUID v4 批量生成器；
            </li><li>完善工具页独立指南、常见问题和结构化数据；</li><li>
              加强 360px 移动端布局、社交分享信息和站点地图。
            </li>
          </ul>
        </div>
      </article>
      <article class="timeline-item">
        <time datetime="2026-07-19">2026 年 7 月 19 日</time><div>
          <p class="eyebrow">0.2.0 · 首个可用工具</p><h2>
            JSON 格式化与校验
          </h2><ul>
            <li>支持 2 空格、4 空格、Tab 缩进和压缩模式；</li><li>
              无效输入会显示行、列和附近上下文；
            </li><li>
              超出安全整数范围的数字保持原始词法，不会被静默改写；
            </li><li>加入示例、复制、下载、清空、大小与处理耗时状态。</li>
          </ul>
        </div>
      </article>
      <article class="timeline-item">
        <time datetime="2026-07-19">2026 年 7 月 19 日</time><div>
          <p class="eyebrow">0.1.0 · 项目基础</p><h2>站点骨架与设计系统</h2><ul>
            <li>建立 Astro + React + TypeScript 静态应用；</li><li>
              完成首页、目录、分类、工具外壳和信息页面；
            </li><li>加入 GitHub Pages 子路径支持与统一工具注册表；</li><li>
              发布本地处理原则和隐私说明。
            </li>
          </ul>
        </div>
      </article>
    </div>
  </div>
</BaseLayout>
