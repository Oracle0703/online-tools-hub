---
import BaseLayout from "../layouts/BaseLayout.astro";
import { releases } from "../lib/experience-content";
import { pathFor } from "../lib/tool-registry";

const origin = Astro.site ?? new URL(Astro.url.origin);
const structuredData = {
  "@type": "CollectionPage",
  name: "Online Tools Hub 更新日志",
  url: new URL(pathFor("/changelog/"), origin).href,
  description: "Online Tools Hub 的新工具、修复与隐私行为变更记录。",
  inLanguage: "zh-CN",
};
const dateFormatter = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
});
const formatDate = (date: (typeof releases)[number]["date"]) =>
  dateFormatter.format(new Date(`${date}T00:00:00Z`));
---

<BaseLayout
  title="更新日志 — Online Tools Hub"
  description="查看 Online Tools Hub 的新工具、修复和隐私相关行为变更。"
  structuredData={structuredData}
>
  <div class="container page-shell">
    <header class="page-intro">
      <p class="eyebrow">更新日志</p>
      <h1>每一次变化，都说清楚</h1>
      <p>
        这里记录新工具、问题修复，以及任何可能影响隐私或使用方式的行为变化。
      </p>
    </header>
    <div class="timeline">
      {
        releases.map((release) => (
          <article class="timeline-item">
            <time datetime={release.date}>{formatDate(release.date)}</time>
            <div>
              <p class="eyebrow">
                {release.version} · {release.theme}
              </p>
              <h2>{release.title}</h2>
              <p>{release.summary}</p>
              <ul>
                {release.changes.map((change) => (
                  <li>{change}</li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</BaseLayout>
