{
  "name": "online-tools-hub",
  "version": "0.7.0",
  "private": true,
  "type": "module",
  "description": "A privacy-first collection of browser-based utilities.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build && node scripts/verify-build.mjs",
    "check": "astro check",
    "typecheck": "astro check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:lighthouse": "lhci autorun",
    "preview": "astro preview",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run test:coverage && npm run build"
  },
  "engines": {
    "node": "^22.22.3 || ^24.16.0 || >=26.3.0",
    "npm": ">=9.6.5"
  },
  "dependencies": {
    "@astrojs/react": "6.0.1",
    "@upng/upng-js": "2.2.2",
    "astro": "7.1.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@lhci/cli": "0.15.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "eslint-plugin-astro": "3.0.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "prettier-plugin-astro": "0.14.1",
    "selenium-webdriver": "4.46.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
